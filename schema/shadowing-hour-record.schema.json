{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Cross-Clinical/shadowing-hours-schema/main/schema/shadowing-hour-record.schema.json",
  "title": "ShadowingHourRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "student", "host", "site", "specialty", "started_at", "ended_at", "hours", "mode", "verification"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0" },
    "student": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string" },
        "school": { "type": "string" }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "credential_tier"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "credential_tier": { "type": "string" }
      }
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "location": { "type": "string" }
      }
    },
    "specialty": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string" },
    "ended_at": { "type": "string" },
    "hours": { "type": "number", "exclusiveMinimum": 0 },
    "mode": { "type": "string", "enum": ["in_person", "virtual"] },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "verified_at": { "type": "string" },
        "verifier_name": { "type": "string" }
      }
    }
  }
}
